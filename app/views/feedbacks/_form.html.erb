<!-- Container wraps the entire form layout, not inside the form itself -->

<!-- 'sm' means small (576px); .sm- classes take effect at ≥576px -->
<!-- mx-auto centers the container on all screen sizes by default -->
<!-- mx-sm-0 overrides the centering and left-aligns the container on screens ≥576px -->
<div class="container mx-auto mx-sm-0">
  <%= form_with(model: feedback, html: { class: "needs-validation" }) do |form| %>
    
    <% if feedback.errors.any? %>
      <div class="alert alert-danger">
        <h4 class="alert-heading"><%= pluralize(feedback.errors.count, "error") %> prohibited this feedback from being saved:</h4>
        <ul class="mb-0">
          <% feedback.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="row">
      <div class="col-md-6">

        <div class="mb-3">
          <%= form.label :companion, class: "form-label" %>
          <%= form.text_field :companion, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= form.label :mobility, class: "form-label" %>
          <%= form.text_field :mobility, list: "mobility_options",
              class: "form-control", autocomplete: "off",
              placeholder: "Click to select or type a mobility aid" %>
          <datalist id="mobility_options">
            <% Feedback::MOBILITY_OPTIONS.each do |option| %>
              <option value="<%= option %>">
            <% end %>
          </datalist>
        </div>

        <div class="mb-3">
          <%= form.label :pick_up_time, class: "form-label" %>
          <%= form.text_field :pick_up_time, type: "time", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= form.label :drop_off_time, class: "form-label" %>
          <%= form.text_field :drop_off_time, type: "time", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= form.label :fare, class: "form-label" %>
          <%= form.number_field :fare, step: 0.01, class: "form-control", id: "feedback_fare_field" %>

          <!-- Quick Amount Selection Buttons -->
          <div class="mt-2 mb-3">
            <label class="form-label text-muted small">Quick Select:</label>
            <div class="btn-group">
              <% [0, 5, 10, 20].each do |amount| %>
                <button type="button" class="btn btn-sm btn-outline-secondary feedback-fare-quick-select"
                        data-amount="<%= amount %>">
                  $<%= amount %>
                </button>
              <% end %>
            </div>
            <script>
              document.addEventListener('turbo:load', function() {
                const amountField = document.getElementById('feedback_fare_field');
                const quickButtons = document.querySelectorAll('.feedback-fare-quick-select');

                quickButtons.forEach(button => {
                  button.addEventListener('click', function() {
                    amountField.value = this.getAttribute('data-amount');
                  });
                });
              });
            </script>
          </div>
        </div>

        <div class="mb-3">
          <%= form.label :note, class: "form-label" %>
          <%= form.text_field :note, class: "form-control" %>
        </div>

        <!-- text-center centers the button by default -->
        <!-- text-sm-start overrides it to left-align the button on screens ≥576px -->
        <div class="mt-4 text-sm-start text-center">
          <%= form.button "Save", type: :submit, class: "btn btn-primary px-5 ride-feedback-btn" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
